{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm install && DATABASE_URL=postgresql://dummy:dummy@localhost:5432/dummy npx prisma generate"
  },
  "deploy": {
    "startCommand": "npx prisma db push --accept-data-loss && node src/index.js",
    "healthcheckPath": "/health",
    "healthcheckTimeout": 60,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
